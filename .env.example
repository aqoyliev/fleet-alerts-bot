# ── Single-company Fleet Alerts Bot — deployment template ───────────────────────
# Copy this file to .env and fill it in for the ONE company this deployment serves.
# To onboard another company, clone this branch and create a fresh .env + database.

# Telegram bot token from @BotFather
BOT_TOKEN=123456:your-token-here

# Bootstrap super-admin Telegram IDs (comma-separated). They can manage other admins.
ADMINS=11111111,22222222

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/fleet_alerts

# ── The company this deployment serves ──────────────────────────────────────────
COMPANY_SLUG=hf
COMPANY_NAME=HF Trucking

# Minimum speeding severity to alert on: low | medium | high | critical
SPEEDING_MIN_SEVERITY=high

# ── Samsara (leave blank if this company has no Samsara fleet) ───────────────────
SAMSARA_API_KEY=
SAMSARA_WEBHOOK_SECRET=

# ── Motive / KeepTruckin (leave blank to skip webhook signature verification) ────
MOTIVE_WEBHOOK_SECRET=
