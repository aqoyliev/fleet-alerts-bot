# ── Required ────────────────────────────────────────────────────────────────
BOT_TOKEN=                       # from @BotFather
ADMINS=                          # super-admin Telegram IDs, space/comma separated
DATABASE_URL=                    # postgresql://user:pass@host:5432/dbname
COMPANY_SLUG=                    # e.g. mz-cargo
GROUP_CHAT_ID=                   # default Telegram group id (starts with -100…)
ip=                              # public host of this server (IP or domain, no protocol)

# ── Samsara ─────────────────────────────────────────────────────────────────
SAMSARA_API_KEY=                 # Samsara REST API token (Read Safety scope)
SAMSARA_WEBHOOK_SECRET=          # any random string; same value goes into Samsara webhook config

# ── Motive (unused for this deployment — leave blank) ───────────────────────
MOTIVE_WEBHOOK_SECRET=

# ── Optional ────────────────────────────────────────────────────────────────
REDIS_URL=                       # redis://host:6379/0 — omit for in-memory FSM
